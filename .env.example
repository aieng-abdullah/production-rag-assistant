# OpenAI API (Required)
OPENAI_API_KEY=sk-your-key-here

# LangSmith Tracing (Optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=rag-research-assistant

# ChromaDB (Leave empty for local PersistentClient, set for production)
CHROMA_HOST=
CHROMA_PORT=8000

# Model Configuration
LLM_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO
